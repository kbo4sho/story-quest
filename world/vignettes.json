      "cast": [
        {
          "name": "Dr. Lin",
          "role_short": "paleontologist",
          "position": { "angleDeg": 60, "radius": 5 },
          "appearance": { "costume": "archeologist", "tint": 14934190 },
          "dialogue": [
            "Welcome to the dig site! I'm Dr. Lin. I find dinosaur bones for a living.",
            "These rocks around us are very, very old. Older than ANY animal alive today.",
            "Sometimes when an animal died, mud covered it just right, and over millions of years it turned to stone.",
            "We call those stone bones FOSSILS. They're like nature's photographs.",
            "Every fossil teaches us a little more about how dinosaurs lived."
          ]
        },
        {
          "name": "Rex",
          "role_short": "tyrannosaurus",
          "position": { "angleDeg": 180, "radius": 7 },
          "appearance": { "model": "frog", "tint": 9923125, "scale": 1.4 },
          "dialogue": [
            "ROAR! Don't be scared, I'm friendly. I'm a T-Rex.",
            "I had teeth as long as bananas. Big ones. For eating other dinosaurs.",
            "But my arms? Tiny! I bet I couldn't reach my own snack.",
            "I lived a long, long time ago — about sixty-six MILLION years.",
            "Then a huge rock from space crashed into Earth, and most of us couldn't survive."
          ]
        },
        {
          "name": "Trixie",
          "role_short": "triceratops",
          "position": { "angleDeg": 290, "radius": 6 },
          "appearance": { "model": "frog", "tint": 7187574, "scale": 1.1 },
          "dialogue": [
            "Hello! I'm Trixie. Three horns, big bony frill. See?",
            "Don't worry — I only ate plants. Lots and lots of leaves and ferns.",
            "My horns weren't for eating. They were for protecting my babies from fellas like Rex over there.",
            "Some dinosaurs, like the small fast ones, became BIRDS. Yes, really!",
            "Next time you see a robin, give a little wave to a tiny dinosaur cousin."
          ]
        }
      ]
    }
