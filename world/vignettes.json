        { "op": "ridge",   "from": { "angleDeg": 30, "radius": 6 }, "to": { "angleDeg": 60, "radius": 8 }, "width": 2, "height": 1.0 }
      ],
      "set_pieces": [
        { "type": "pool",   "position": { "angleDeg": 270, "radius": 5 }, "scale": 2.8, "color": 16219136, "glow": true, "opacity": 0.95 },
        { "type": "pool",   "position": { "angleDeg": 290, "radius": 9 }, "scale": 1.4, "color": 16219136, "glow": true, "opacity": 0.9 },
        { "type": "pillar", "position": { "angleDeg": 260, "radius": 7.5 }, "scale": [0.6, 4.0, 0.6], "color": 12961221 },
        { "type": "pillar", "position": { "angleDeg": 280, "radius": 8.5 }, "scale": [0.5, 3.5, 0.5], "color": 12961221 },
        { "type": "mound",  "position": { "angleDeg": 100, "radius": 8 }, "scale": 0.8, "color": 4471619 },
        { "type": "mound",  "position": { "angleDeg": 115, "radius": 7.5 }, "scale": 0.7, "color": 4471619 },
        { "type": "mound",  "position": { "angleDeg": 85,  "radius": 8.5 }, "scale": 0.6, "color": 4471619 },
        { "type": "mound",  "position": { "angleDeg": 30,  "radius": 8 }, "scale": 0.55, "color": 6118749 },
        { "type": "crystal","position": { "angleDeg": 30,  "radius": 8.5 }, "y": 0.6, "scale": 0.4, "color": 14366500, "glow": true },
        { "type": "flag",   "position": { "angleDeg": 0,   "radius": 7 }, "scale": 2.0, "color": 14366500 }
      ],
      "cast": [
        {
          "name": "Dr. Kai",
          "role_short": "vulcanologist",
          "position": { "angleDeg": 90, "radius": 5 },
          "appearance": {
            "costume": "scientist", "tint": 16447968,
            "outfit": [
              { "kind": "lab_coat", "color": 16316664 },
              { "kind": "wide_brim_hat", "color": 6308875, "bandColor": 16219136 },
              { "kind": "tool", "color": 6308875, "headColor": 16762775, "side": "right" }
            ]
          },
          "dialogue": [
            "Welcome! I'm Dr. Kai. I study volcanoes for a living.",
            "Underneath us, deep down, the rock is so hot it MELTS. We call that melted rock magma.",
            "When pressure builds, magma pushes up and out. Then it's called lava.",
            "Volcanoes scare people, but they also build new land. Every Hawaiian island grew from one.",
            "My instruments listen to the mountain's heartbeat. Right now, she's calm."
          ]
        },
        {
          "name": "Pele",
          "role_short": "fire goddess",
          "position": { "angleDeg": 210, "radius": 6 },
          "appearance": { "costume": "fire_goddess" },
          "dialogue": [
            "Aloha, little one. I am Pele. The Hawaiian people have told stories about me for a very long time.",
            "They say I live inside the volcano. When she erupts, it is me dancing.",
            "Long-ago people did not have Dr. Kai's instruments. They told stories to remember.",
            "Stories and science both teach us — they are two ways of looking at the same wonder.",
            "Be respectful of fire, child. It can warm you, and it can change a whole island."
          ]
        },
        {
          "name": "Noa",
          "role_short": "village child",
          "position": { "angleDeg": 100, "radius": 6 },
          "appearance": {
            "model": "finn", "tint": 16770730, "scale": 0.72,
            "outfit": [{ "kind": "satchel", "color": 7948609, "side": "right" }]
          },
          "dialogue": [
            "Hi! I'm Noa. I live in the village down the slope.",
            "My grandma says the soil here is the BEST for growing taro and sweet potato.",
            "It's because of old lava. When it cools, it breaks down into super-rich dirt.",
            "So even though volcanoes are scary sometimes, they feed us too.",
            "Want to come pick fruit? My family always has extra."
          ]
        }
      ]
    }
