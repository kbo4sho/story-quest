        {
          "name": "Dr. Amara",
          "role_short": "marine biologist",
          "position": { "angleDeg": 0, "radius": 0 },
          "appearance": { "costume": "scientist", "tint": 14411500 },
          "dialogue": [
            "Hi! I'm Dr. Amara. I study the ocean — every creature, every current.",
            "Did you know the sea covers most of our planet? More than the land does.",
            "Down deep, it's dark and cold, but glowing fish make their own light.",
            "Up here in the shallow pools, you'll find tiny crabs, anemones, and starfish.",
            "Look closely — the more you watch, the more the ocean shows you."
          ]
        },
        {
          "name": "Echo",
          "role_short": "dolphin",
          "position": { "angleDeg": 90, "radius": 7 },
          "appearance": { "model": "frog", "tint": 6262248, "scale": 1.0 },
          "dialogue": [
            "Click-click! Hi there! I'm Echo. I'm a dolphin.",
            "We dolphins talk to each other with whistles and clicks.",
            "Every dolphin in my pod has its own special whistle — like a name.",
            "We help each other hunt, and we play together. The ocean is our playground.",
            "Want to swim? I'll show you the kelp forest!"
          ]
        },
        {
          "name": "Captain Suri",
          "role_short": "old fisher",
          "position": { "angleDeg": 215, "radius": 7 },
          "appearance": { "costume": "sailor", "tint": 13684960, "scale": 1.05 },
          "dialogue": [
            "Aye, hello there. I've sailed these waters fifty years.",
            "The sea changes every day. Some mornings calm as glass, some afternoons tall and angry.",
            "But she gives us food, and weather, and salt for our soup.",
            "We must be gentle with her. Take only what we need.",
            "Listen to the waves long enough, and you'll hear stories the land has forgotten."
          ]
        }
      ]
